{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pack firmware",
      "type": "shell",
      "command": "dart",
      "args": ["run", "bin/pack_firmware.dart"],
      "options": { "cwd": "${workspaceFolder}/../tools/scripts/" },
      "group": "build",
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "dedicated", "showReuseMessage": false, "clear": false }
    },
    {
      "label": "Upload firmware",
      "type": "shell",
      "command": "dart",
      "args": ["run", "bin/upload_firmware.dart", "${input:device_ip}"],
      "options": { "cwd": "${workspaceFolder}/../tools/scripts/" },
      "group": "build",
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "dedicated", "showReuseMessage": false, "clear": false }
    }
  ],
  "inputs": [
    {
      "id": "device_ip",
      "type": "promptString",
      "description": "IP adresa uređaja"
    }
  ]
}